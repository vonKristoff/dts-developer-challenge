{% from "govuk/components/button/macro.njk" import govukButton %}

{% extends "template.njk" %}

{% block content %}
  <h1 class="govuk-heading-xl">Task Dashboard</h1>

  <div style="margin-bottom: 30px; display: flex; gap: 15px; align-items: center;">
    {{ govukButton({
      text: "Create new task",
      href: "/tasks/new",
      attributes: {
        "aria-label": "Create a new task"
      }
    }) }}
    <a href="/tasks" class="govuk-link" aria-label="View all tasks">View all tasks</a>
  </div>

  <div class="govuk-grid-row" role="list" aria-label="Task summary statistics">
    <div class="govuk-grid-column-one-quarter" role="listitem">
      <div class="govuk-inset-text" style="background-color: #f3f2f1; border-left: 5px solid #b1b4b6;" aria-label="Total tasks count">
        <h2 class="govuk-heading-m">Total</h2>
        <p class="govuk-body-l" style="font-size: 36px; margin: 0;"><strong>{{ counts.total }}</strong></p>
      </div>
    </div>
    <div class="govuk-grid-column-one-quarter" role="listitem">
      <div class="govuk-inset-text" style="background-color: #f3f2f1; border-left: 5px solid #00703c;" aria-label="Open tasks count">
        <h2 class="govuk-heading-m">Open</h2>
        <p class="govuk-body-l" style="font-size: 36px; margin: 0;"><strong>{{ counts.open }}</strong></p>
      </div>
    </div>
    <div class="govuk-grid-column-one-quarter" role="listitem">
      <div class="govuk-inset-text" style="background-color: #f3f2f1; border-left: 5px solid #ffdd00;" aria-label="In progress tasks count">
        <h2 class="govuk-heading-m">In Progress</h2>
        <p class="govuk-body-l" style="font-size: 36px; margin: 0;"><strong>{{ counts.inProgress }}</strong></p>
      </div>
    </div>
    <div class="govuk-grid-column-one-quarter" role="listitem">
      <div class="govuk-inset-text" style="background-color: #f3f2f1; border-left: 5px solid #00703c;" aria-label="Completed tasks count">
        <h2 class="govuk-heading-m">Completed</h2>
        <p class="govuk-body-l" style="font-size: 36px; margin: 0;"><strong>{{ counts.completed }}</strong></p>
      </div>
    </div>
  </div>

{% endblock %}
